# =============================================================================
# Sluice - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# Database (required)
# Local Docker: these defaults match docker-compose.yml, no changes needed
# Production (Neon): use your Neon connection string with ?sslmode=verify-full
# Pool size auto-adjusts: 3 for Neon (serverless), 10 for local
DATABASE_URL=postgresql://goldminer:goldminer@localhost:5432/goldminer

# AI Gateway (required for AI features: insights, personas, ensemble queries)
# Get your key at https://console.anthropic.com/
# App will warn at startup if not set
# AI_GATEWAY_KEY=sk-ant-...

# Agent authentication (required for production)
# Local dev: auto-generated via .agent-token file
# Production: set this for SSE agent transport
# AGENT_AUTH_TOKEN=your-agent-token

# Agent WebSocket port (local development only)
# Must match AGENT_PORT in npm scripts (default: 9334)
NEXT_PUBLIC_AGENT_PORT=9334

# Cron job authentication (required for automation endpoints)
# Set any secret string to secure /api/cron/* endpoints
# App will warn at startup if not set
# CRON_SECRET=your-secret-here

# Auto-fetch feature flag (optional)
# When set to 'true', the check-feeds cron job will poll RSS feeds and dispatch workflows.
# When unset or any other value, the cron endpoint returns immediately without doing work.
# This prevents unnecessary database queries and workflow dispatches when auto-fetch is not needed.
# ENABLE_AUTO_FETCH=true

# MCP authentication
# MCP endpoints are secured via Better Auth OAuth in production.
# In development, MCP endpoints are open (no auth required).
# Ensure BETTER_AUTH_SECRET is set (see above) for production OAuth.

# MCP external service authentication (machine-to-machine)
# JSON array of external auth providers. Each provider needs:
#   name     - identifier for logging (e.g., "clerk", "auth0")
#   jwksUrl  - JWKS endpoint URL
#   issuer   - (optional) expected JWT issuer claim
#   audience - (required) expected JWT audience claim
# MCP_EXTERNAL_AUTH_PROVIDERS='[{"name":"clerk","jwksUrl":"https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json","issuer":"https://your-clerk-instance.clerk.accounts.dev","audience":"your-sluice-audience"}]'

# Authentication (Better Auth)
# Required for production -- generate with: openssl rand -base64 32
# In development, Better Auth uses a default secret (insecure)
# BETTER_AUTH_SECRET=your-secret-here
# BETTER_AUTH_URL=http://localhost:3001

# Google OAuth (required for production SSO)
# Reuse the same Google Cloud OAuth client across projects.
# Add this app's callback URL to Google Console:
#   https://YOUR_DOMAIN/api/auth/callback/google
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Domain restriction (optional, defaults to devobsessed.com)
# Only emails ending with this domain can sign in
# ALLOWED_EMAIL_DOMAIN=devobsessed.com

# Admin emails (required for access request management)
# Comma-separated list of email addresses that can approve/deny access requests
# These users see the "Access Requests" link on the Settings page
# ADMIN_EMAILS=admin@devobsessed.com,other@devobsessed.com

# Supadata transcript API (optional, for production transcript fetching)
# When set, Supadata is used as primary provider with InnerTube as fallback.
# When unset, InnerTube is used directly (works locally, blocked on datacenter IPs).
# Get your key at https://supadata.ai/
# SUPADATA_API_KEY=sd_...
